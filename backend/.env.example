# App Configuration
APP_NAME=Social Listening Platform
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL local)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/social_listening

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# Meilisearch (optional - leave empty to use PostgreSQL full-text search)
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=masterKey

# JWT Security
SECRET_KEY=change-this-to-a-very-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI Provider Configuration
# Supported providers: dummy, openai, gemini
# - dummy: Keyword-based analysis (for testing, no API key required)
# - openai: OpenAI GPT-4 (requires OPENAI_API_KEY)
# - gemini: Google Gemini Pro (requires GEMINI_API_KEY)
AI_PROVIDER=dummy

# OpenAI Configuration (required if AI_PROVIDER=openai)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini Configuration (required if AI_PROVIDER=gemini)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# Deprecated AI providers (not implemented yet)
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Background Scheduler
# Set to false to disable automated scheduled scans
SCHEDULER_ENABLED=true
ENABLE_EMBEDDED_SCHEDULER=true

# Social crawl (Twitter / Reddit / News) — every 5 minutes
SOCIAL_CRAWL_ENABLED=true
SOCIAL_CRAWL_INTERVAL_MINUTES=5
TWITTER_BEARER_TOKEN=
NEWS_API_KEY=

# DistilBERT sentiment microservice (ai-services/app.py on port 5001)
SENTIMENT_SERVICE_URL=http://localhost:5001

# Facebook (optional)
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# YouTube (optional)
YOUTUBE_API_KEY=

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email Notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# SMS Notifications (optional - Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Zalo (optional)
ZALO_OA_ID=
ZALO_ACCESS_TOKEN=
